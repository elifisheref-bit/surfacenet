# Unit cube centred at origin, side length 1m
# 8 vertices, 12 triangular faces

v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

# bottom (z = -0.5), normal -z
f 1 3 2
f 1 4 3
# top (z = +0.5), normal +z
f 5 6 7
f 5 7 8
# front (y = -0.5), normal -y
f 1 2 6
f 1 6 5
# back (y = +0.5), normal +y
f 4 8 7
f 4 7 3
# left (x = -0.5), normal -x
f 1 5 8
f 1 8 4
# right (x = +0.5), normal +x
f 2 3 7
f 2 7 6
