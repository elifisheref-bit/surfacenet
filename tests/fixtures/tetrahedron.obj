# Regular tetrahedron, side length 1m
# 4 vertices, 4 triangular faces

v 0.0  0.0                  0.0
v 1.0  0.0                  0.0
v 0.5  0.8660254037844387   0.0
v 0.5  0.28867513459481287  0.816496580927726

# bottom (z=0), normal -z
f 1 3 2
# front (low-y), normal roughly -y
f 1 2 4
# back-right, normal roughly +x+y
f 2 3 4
# left, normal roughly -x+y
f 1 4 3
